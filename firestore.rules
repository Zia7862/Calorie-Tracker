rules_version = '2';
// Deploy in Firebase Console → Firestore → Rules (merge with any extra rules you already need).
// Enables community leaderboard: authenticated users can read dailyStats; each user may only write their own row.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /dailyStats/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
  }
}
